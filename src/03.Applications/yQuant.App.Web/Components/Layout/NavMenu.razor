@using yQuant.App.Web.Services
@inject SystemHealthService HealthService
@implements IDisposable

<div style="display: flex; flex-direction: column; height: 100%;">
    <MudNavMenu>
        <MudNavLink Href="dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard
        </MudNavLink>
        <MudNavLink Href="assets" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountBalance">Assets
        </MudNavLink>
        <MudNavLink Href="scheduled" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Schedule">Scheduled Orders
        </MudNavLink>
        <MudNavLink Href="liquidate" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Sell">Liquidate
        </MudNavLink>
        <MudNavLink Href="orderform" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ShoppingCart">Buy Order
        </MudNavLink>
        <MudNavLink Href="reports" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Assessment">Reports
        </MudNavLink>
    </MudNavMenu>

    <div style="margin-top: auto; padding: 16px 16px 8px 16px; font-size: 0.75rem; line-height: 1.5;">
        <div style="color: var(--mud-palette-text-secondary); margin-bottom: 4px; font-weight: 500;">Service Status
        </div>
        <div style="color: @(isRedisHealthy ? "limegreen" : "red")">• Redis</div>
        <div style="color: @(isBrokerGatewayHealthy ? "limegreen" : "red")">• BrokerGateway</div>
        <div style="color: @(isOrderComposerHealthy ? "limegreen" : "red")">• OrderComposer</div>
        <div style="color: @(isWebhookHealthy ? "limegreen" : "red")">• Webhook</div>
    </div>
</div>

@code {
    private bool isRedisHealthy = false;
    private bool isBrokerGatewayHealthy = false;
    private bool isOrderComposerHealthy = false;
    private bool isWebhookHealthy = false;

    private Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new Timer(async _ => await CheckHealthAsync(), null, TimeSpan.Zero, TimeSpan.FromSeconds(5));
    }

    private async Task CheckHealthAsync()
    {
        isRedisHealthy = await HealthService.CheckRedisAsync();
        isBrokerGatewayHealthy = await HealthService.CheckServiceAsync("BrokerGateway");
        isOrderComposerHealthy = await HealthService.CheckServiceAsync("OrderComposer");
        isWebhookHealthy = await HealthService.CheckServiceAsync("Webhook");

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}